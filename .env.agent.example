# TeleCloud Local Agent
# Copy this file to .env.agent and fill the values.

# Online TeleCloud base URL
TELECLOUD_BASE_URL=https://file.utamadigital.id

# Must match LOCAL_AGENT_TOKEN in Cloudflare Environment Variables
LOCAL_AGENT_TOKEN=change-this-long-random-token

# Telegram bot token and channel IDs
BOT_TOKEN=123456789:AA_your_bot_token
TELEGRAM_API_BASE=https://api.telegram.org

# Recommended: use 3 Telegram channels
TELEGRAM_ORIGINAL_CHAT_ID=-100xxxxxxxxxx
TELEGRAM_PREVIEW_CHAT_ID=-100xxxxxxxxxx
TELEGRAM_THUMBNAIL_CHAT_ID=-100xxxxxxxxxx

# Optional local dashboard port
LOCAL_AGENT_PORT=8788

# Optional safety limit for local upload before sending to Telegram
LOCAL_AGENT_MAX_FILE_MB=2048
